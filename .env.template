# ============================================================
# AI Shopping Assistant — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.template .env
# ============================================================


# ── LLM Provider ─────────────────────────────────────────────
# Mistral AI (cloud inference — recommended)
MISTRAL_API_KEY=your_mistral_api_key_here

# LLM model name (change to switch providers)
# Options: mistral-large-latest | mistral-medium-latest | open-mistral-7b
LLM_MODEL=mistral-large-latest

# Optional: LangSmith tracing (leave blank to disable)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=shopping-assistant


# ── MySQL (Users + Orders — relational) ──────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=shopping_assistant


# ── MongoDB (Products + Cart + Embeddings) ───────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=shopping_assistant

# Set to 1 if using MongoDB Atlas (cloud)
MONGO_ATLAS=0
# Atlas connection string (only if MONGO_ATLAS=1)
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/


# ── Redis (Session cache) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Uncomment if Redis requires auth:
# REDIS_PASSWORD=your_redis_password_here


# ── Flask API Backend ─────────────────────────────────────────
FLASK_HOST=localhost
FLASK_PORT=5001
FLASK_DEBUG=false
# Secret key for Flask session signing
FLASK_SECRET_KEY=change_this_to_a_random_secret_string


# ── Email (Gmail SMTP — async order confirmations) ───────────
# Use a Gmail App Password, NOT your regular Gmail password.
# Enable at: myaccount.google.com → Security → App passwords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password_here


# ── NLP / Sentence-Transformers ──────────────────────────────
# Local model name (downloaded once on first run to ~/.cache/huggingface)
NLP_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimension for the chosen model
# all-MiniLM-L6-v2  → 384
# all-mpnet-base-v2 → 768
NLP_EMBEDDING_DIM=384

# Semantic similarity threshold (0.0–1.0; lower = more results)
NLP_SIMILARITY_THRESHOLD=0.35

# Number of NLP worker processes (set to physical core count)
# AMD Ryzen AI 7 350 = 8 cores → use 6 to leave 2 for OS + Streamlit
NLP_WORKER_PROCESSES=6


# ── AMD Ryzen AI 7 350 Optimization ─────────────────────────
# Number of CPU threads for PyTorch/sentence-transformers
# (Set to half your logical core count for balanced throughput)
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
TOKENIZERS_PARALLELISM=false

# Enable AMD-specific optimizations
AMD_OPTIMIZE=true
